.hypothesis/
.coverage
.coverage.*
htmlcov/

# Environment / secrets
.env
.env.*
!.env.example
.largestack/

# Jarvis demo bundle: keep the source (jarvis_app/), ignore generated artifacts
jarvis_app.zip
jarvis_app/jarvis_data/
.jarvis/

