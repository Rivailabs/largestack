# LARGESTACK environment template
# Copy to .env (or run `largestack setup`). Never commit .env or real API keys.
# .env auto-loads on `import largestack` (does not override real env vars).

LARGESTACK_ENV=development
LARGESTACK_LOG_LEVEL=INFO

# Provider selection for examples:
# - If LARGESTACK_DEFAULT_MODEL is empty, examples prefer DeepSeek when its key is set.
# - Set LARGESTACK_DEFAULT_MODEL to force a provider/model.
LARGESTACK_DEFAULT_MODEL=
LARGESTACK_DEFAULT_LLM=deepseek/deepseek-chat

# Cloud provider keys. Leave blank unless you use that provider.
LARGESTACK_DEEPSEEK_API_KEY=
LARGESTACK_OPENAI_API_KEY=
LARGESTACK_ANTHROPIC_API_KEY=
LARGESTACK_GROQ_API_KEY=
LARGESTACK_GOOGLE_API_KEY=
LARGESTACK_COHERE_API_KEY=

# Local provider options.
LARGESTACK_ENABLE_OLLAMA=0
LARGESTACK_OLLAMA_BASE_URL=http://localhost:11434

# API/dashboard auth for local container validation. Change in real deployments.
LARGESTACK_API_KEY=
LARGESTACK_DASHBOARD_KEY=

# Database/compose. Change before any shared environment.
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=
POSTGRES_DSN=

# Optional feature toggles.
LARGESTACK_ENABLE_PRESIDIO_PII=0
LARGESTACK_ENABLE_NLI_GUARD=0
LARGESTACK_LICENSE_KEY=
