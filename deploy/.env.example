# Required for protected API routes in production
LARGESTACK_ENV=production
LARGESTACK_API_KEY=change-me-long-random-api-key
LARGESTACK_DASHBOARD_KEY=change-me-long-random-dashboard-key

# Required infra secrets
POSTGRES_USER=largestack
POSTGRES_PASSWORD=change-me-long-random-postgres-password
POSTGRES_DB=largestack
REDIS_PASSWORD=change-me-long-random-redis-password
GRAFANA_ADMIN_PASSWORD=change-me-long-random-grafana-password

# At least one LLM provider key, or use local Ollama/LiteLLM config
LARGESTACK_OPENAI_API_KEY=sk-...
# LARGESTACK_DEEPSEEK_API_KEY=...
# LARGESTACK_ANTHROPIC_API_KEY=sk-ant-...

# Optional local/vector/observability
LARGESTACK_QDRANT_URL=http://qdrant:6333
LARGESTACK_OLLAMA_BASE_URL=http://host.docker.internal:11434
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
