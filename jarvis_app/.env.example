# Copy to .env or export these in your shell.

# DeepSeek (default provider)
LARGESTACK_DEEPSEEK_API_KEY=sk-your-deepseek-key

# Optional: use a different model
# LARGESTACK_DEFAULT_MODEL=openai/gpt-4o-mini
# LARGESTACK_OPENAI_API_KEY=sk-your-openai-key

# Optional: where Jarvis stores notes/facts (default: ~/.jarvis)
# JARVIS_DATA_DIR=./jarvis_data
