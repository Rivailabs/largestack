 # -------------------- FAISS Persistent --------------------
 
+_MACOS_ARM64 = platform.system() == "Darwin" and platform.machine() == "arm64"
+
+
+def _run_faiss_persistent_subprocess(case: str, tmp_path) -> bool:
+    """Exercise faiss-cpu in a fresh process on macOS arm64.
+
+    The native faiss-cpu extension can segfault the long-running pytest process
+    on macOS arm64 after earlier vector store tests. Isolating these cases keeps
+    coverage real without letting a native teardown bug abort unrelated tests.
+    """
+    if not _MACOS_ARM64:
+        return False
+
+    code = textwrap.dedent(
+        """
+        import asyncio
+        import os
+        from pathlib import Path
+        import sys
+
+        try:
+            import faiss  # noqa: F401
+        except ModuleNotFoundError:
+            print("FAISS_IMPORT_MISSING", file=sys.stderr)
+            raise SystemExit(86)
+
+        from largestack._vectorstores import FaissPersistentStore
+
+        async def main():
+            case = os.environ["FAISS_TEST_CASE"]
+            tmp_path = Path(os.environ["FAISS_TEST_TMPDIR"])
+
+            if case == "upsert_query":
+                idx_path = str(tmp_path / "test.faiss")
+                meta_path = str(tmp_path / "test.json")
+                store = FaissPersistentStore(
+                    index_path=idx_path, meta_path=meta_path, dim=4, metric="cosine",
+                )
+                await store.upsert([
+                    {"id": "doc1", "vector": [1.0, 0.0, 0.0, 0.0], "metadata": {"title": "A"}},
+                    {"id": "doc2", "vector": [0.0, 1.0, 0.0, 0.0], "metadata": {"title": "B"}},
+                ])
+                assert Path(idx_path).exists()
+                assert Path(meta_path).exists()
+                results = await store.query([1.0, 0.0, 0.0, 0.0], top_k=1)
+                assert len(results) == 1
+                assert results[0]["id"] == "doc1"
+
+            elif case == "survives_restart":
+                idx_path = str(tmp_path / "p.faiss")
+                meta_path = str(tmp_path / "p.json")
+                store1 = FaissPersistentStore(idx_path, meta_path, dim=3, metric="cosine")
+                await store1.upsert([
+                    {"id": "x", "vector": [1.0, 0.0, 0.0], "metadata": {"v": 1}}
+                ])
+                await store1.close()
+                store2 = FaissPersistentStore(idx_path, meta_path, dim=3, metric="cosine")
+                results = await store2.query([1.0, 0.0, 0.0], top_k=1)
+                assert results[0]["id"] == "x"
+
+            elif case == "delete":
+                store = FaissPersistentStore(
+                    index_path=str(tmp_path / "d.faiss"),
+                    meta_path=str(tmp_path / "d.json"),
+                    dim=2,
+                    metric="cosine",
+                )
+                await store.upsert([
+                    {"id": "a", "vector": [1.0, 0.0], "metadata": {}},
+                    {"id": "b", "vector": [0.0, 1.0], "metadata": {}},
+                ])
+                await store.delete(["a"])
+                results = await store.query([1.0, 0.0], top_k=5)
+                ids = [r["id"] for r in results]
+                assert "a" not in ids
+                assert "b" in ids
+
+            else:
+                raise AssertionError(f"unknown FAISS test case: {case}")
+
+        asyncio.run(main())
+        """
+    )
+    env = os.environ.copy()
+    env["FAISS_TEST_CASE"] = case
+    env["FAISS_TEST_TMPDIR"] = str(tmp_path)
+    env["PYTHONPATH"] = os.pathsep.join(
+        part for part in (os.getcwd(), env.get("PYTHONPATH", "")) if part
+    )
+    proc = subprocess.run(
+        [sys.executable, "-c", code],
+        cwd=os.getcwd(),
+        env=env,
+        capture_output=True,
+        text=True,
+        timeout=30,
+    )
+    if proc.returncode == 86:
+        pytest.skip("faiss is not installed")
+    assert proc.returncode == 0, proc.stdout + proc.stderr
+    return True
+
+
 @pytest.mark.asyncio
 async def test_faiss_persistent_upsert_and_query(tmp_path):
+    if _run_faiss_persistent_subprocess("upsert_query", tmp_path):
+        return
     pytest.importorskip("faiss")
     from largestack._vectorstores import FaissPersistentStore
 
